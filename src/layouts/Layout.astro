---
interface Props {
  title: string;
  description?: string;
}

const { title, description = 'A practical guide to systems thinking for people who work in organisations.' } = Astro.props;
const year = new Date().getFullYear();
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <title>{title} - Fieldmarks</title>

    <!-- Favicon -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png" />
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />

    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Source+Sans+3:wght@300;400;500&display=swap" rel="stylesheet" />
  </head>
  <body class="min-h-screen flex flex-col">

    <!-- Navigation -->
    <nav id="main-nav" class="fixed top-0 left-0 right-0 z-[100] flex items-center justify-between px-12 py-5 transition-all duration-300" style="background: rgba(255,255,255,0);">
      <div class="flex items-center gap-2.5">
        <a href="/" class="flex items-center gap-2.5 no-underline">
          <svg viewBox="0 0 26 26" fill="none" class="w-[26px] h-[26px]">
            <rect x="1" y="1" width="5" height="5" fill="#221C2B" opacity="0.5"/>
            <rect x="10" y="1" width="5" height="5" fill="#221C2B" opacity="0.5"/>
            <rect x="19" y="1" width="5" height="5" fill="#221C2B" opacity="0.5"/>
            <rect x="1" y="10" width="5" height="5" fill="#221C2B" opacity="0.5"/>
            <rect x="10" y="10" width="5" height="5" fill="#9B51E0"/>
            <rect x="19" y="10" width="5" height="5" fill="#221C2B" opacity="0.5"/>
            <rect x="1" y="19" width="5" height="5" fill="#221C2B" opacity="0.5"/>
            <rect x="10" y="19" width="5" height="5" fill="#221C2B" opacity="0.5"/>
            <rect x="19" y="19" width="5" height="5" fill="#221C2B" opacity="0.5"/>
          </svg>
          <span class="text-[17px] font-normal tracking-[0.02em]" style="color: var(--deep);">Fieldmarks</span>
        </a>
        <span class="text-[14px] font-light hidden sm:inline" style="color: var(--soft);">by <a href="https://mutomorro.com" target="_blank" rel="noopener" class="no-underline transition-colors duration-200" style="color: var(--soft);">Mutomorro</a></span>
      </div>
      <ul class="flex gap-8 list-none m-0 p-0">
        <li><a href="/concepts" class="text-[14px] font-normal no-underline transition-colors duration-200 hover:!text-[var(--deep)]" style="color: var(--soft);">Concepts</a></li>
        <li><a href="/collections" class="text-[14px] font-normal no-underline transition-colors duration-200 hover:!text-[var(--deep)]" style="color: var(--soft);">Collections</a></li>
        <li><a href="/connections" class="text-[14px] font-normal no-underline transition-colors duration-200 hover:!text-[var(--deep)]" style="color: var(--soft);">Connections</a></li>
        <li><a href="/about" class="text-[14px] font-normal no-underline transition-colors duration-200 hover:!text-[var(--deep)]" style="color: var(--soft);">About</a></li>
        <li><a href="/search" class="text-[14px] font-normal no-underline transition-colors duration-200 hover:!text-[var(--deep)]" style="color: var(--soft);">Search</a></li>
      </ul>
    </nav>

    <!-- Main content -->
    <main class="flex-1">
      <slot />
    </main>

    <!-- Footer -->
    <footer class="footer">
      <div class="footer-columns">
        <div class="footer-col">
          <div class="footer-col-heading">Fieldmarks</div>
          <a href="/concepts">Concepts</a>
          <a href="/about">About</a>
          <a href="/collections">Collections</a>
          <a href="/connections">Connections</a>
        </div>
        <div class="footer-col">
          <div class="footer-col-heading">Themes</div>
          <a href="/theme/core-building-blocks">Core building blocks</a>
          <a href="/theme/systems-archetypes">Systems archetypes</a>
          <a href="/theme/complexity-and-uncertainty">Complexity and uncertainty</a>
          <a href="/theme/resilience-and-change">Resilience and change</a>
        </div>
        <div class="footer-col">
          <div class="footer-col-heading">Mutomorro</div>
          <p class="footer-mutomorro-desc">A <a href="https://mutomorro.com" target="_blank" rel="noopener">Mutomorro</a> project</p>
          <p class="footer-mutomorro-tagline">Organisational consulting and thought leadership</p>
        </div>
      </div>
      <div class="footer-bottom">
        <span>Fieldmarks. Free and open.</span>
      </div>
    </footer>

  </body>
</html>

<style is:global>
  :root {
    --deep: #221C2B;
    --mid: #423B49;
    --soft: #9A9399;
    --accent: #9B51E0;
    --warm-bg: #FAF9F7;
    --white: #FFFFFF;
    --border: rgba(34,28,43,0.08);
    --border-hover: rgba(34,28,43,0.18);
  }
  html {
    font-family: 'Source Sans 3', system-ui, sans-serif;
    font-weight: 400;
    color: #3D3D3D;
    scroll-behavior: smooth;
    -webkit-font-smoothing: antialiased;
  }
  h1, h2, h3, h4, h5, h6 { font-weight: 400; }
  *, *::before, *::after { border-radius: 0 !important; }
</style>

<style>
  @media (max-width: 768px) {
    nav { padding: 16px 24px !important; }
  }
  nav.scrolled {
    background: rgba(255,255,255,0.92) !important;
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    border-bottom: 1px solid var(--border);
  }

  /* ====== FOOTER ====== */
  .footer {
    background: #F3F3F3;
    padding: 64px 48px 40px;
  }
  .footer-columns {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 48px;
    margin-bottom: 48px;
  }
  .footer-col {
    display: flex;
    flex-direction: column;
    gap: 10px;
  }
  .footer-col-heading {
    font-size: 12px;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: rgba(34, 28, 43, 0.35);
    margin-bottom: 8px;
  }
  .footer-col a {
    font-size: 14px;
    font-weight: 300;
    color: var(--mid);
    text-decoration: none;
    transition: color 0.2s;
  }
  .footer-col a:hover {
    color: var(--accent);
  }
  .footer-mutomorro-desc {
    font-size: 14px;
    font-weight: 300;
    color: var(--mid);
    margin: 0;
  }
  .footer-mutomorro-desc a {
    font-weight: 400;
  }
  .footer-mutomorro-tagline {
    font-size: 14px;
    font-weight: 300;
    color: rgba(34, 28, 43, 0.4);
    margin: 0;
  }
  .footer-bottom {
    border-top: 1px solid rgba(34, 28, 43, 0.1);
    padding-top: 24px;
  }
  .footer-bottom span {
    font-size: 13px;
    font-weight: 300;
    color: rgba(34, 28, 43, 0.4);
  }

  @media (max-width: 768px) {
    .footer { padding: 40px 24px 32px; }
    .footer-columns {
      grid-template-columns: 1fr;
      gap: 32px;
    }
  }
</style>

<script is:inline>
  const nav = document.getElementById('main-nav');
  window.addEventListener('scroll', () => {
    nav.classList.toggle('scrolled', window.scrollY > 80);
  });
</script>
