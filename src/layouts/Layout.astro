---
interface Props {
  title: string;
  description?: string;
}

const { title, description = 'A practical guide to systems thinking for people who work in organisations.' } = Astro.props;
const year = new Date().getFullYear();
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <title>{title} - Fieldmarks</title>

    <!-- Favicon -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png" />
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />

    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=DM+Sans:ital,wght@0,300;0,400;0,500;1,300&display=swap" rel="stylesheet" />
  </head>
  <body class="min-h-screen flex flex-col">

    <!-- Navigation -->
    <nav id="main-nav" class="fixed top-0 left-0 right-0 z-[100] flex items-center justify-between px-12 py-5 transition-all duration-300" style="background: rgba(255,255,255,0);">
      <a href="/" class="flex items-center gap-2.5 no-underline">
        <svg viewBox="0 0 26 26" fill="none" class="w-[26px] h-[26px]">
          <rect x="1" y="1" width="5" height="5" fill="#221C2B" opacity="0.5"/>
          <rect x="10" y="1" width="5" height="5" fill="#221C2B" opacity="0.5"/>
          <rect x="19" y="1" width="5" height="5" fill="#221C2B" opacity="0.5"/>
          <rect x="1" y="10" width="5" height="5" fill="#221C2B" opacity="0.5"/>
          <rect x="10" y="10" width="5" height="5" fill="#9B51E0"/>
          <rect x="19" y="10" width="5" height="5" fill="#221C2B" opacity="0.5"/>
          <rect x="1" y="19" width="5" height="5" fill="#221C2B" opacity="0.5"/>
          <rect x="10" y="19" width="5" height="5" fill="#221C2B" opacity="0.5"/>
          <rect x="19" y="19" width="5" height="5" fill="#221C2B" opacity="0.5"/>
        </svg>
        <span class="text-[17px] font-normal tracking-[0.02em]" style="color: var(--deep);">Fieldmarks</span>
        <span class="text-[14px] font-light hidden sm:inline" style="color: var(--soft);">by Mutomorro</span>
      </a>
      <ul class="flex gap-8 list-none m-0 p-0">
        <li><a href="/about" class="text-[14px] font-normal no-underline transition-colors duration-200 hover:!text-[var(--deep)]" style="color: var(--soft);">About</a></li>
        <li><a href="/collections" class="text-[14px] font-normal no-underline transition-colors duration-200 hover:!text-[var(--deep)]" style="color: var(--soft);">Collections</a></li>
        <li><a href="/connections" class="text-[14px] font-normal no-underline transition-colors duration-200 hover:!text-[var(--deep)]" style="color: var(--soft);">Connections</a></li>
        <li><a href="/search" class="text-[14px] font-normal no-underline transition-colors duration-200 hover:!text-[var(--deep)]" style="color: var(--soft);">Search</a></li>
      </ul>
    </nav>

    <!-- Main content -->
    <main class="flex-1">
      <slot />
    </main>

    <!-- Footer -->
    <footer class="bg-white border-t px-12 py-12" style="border-color: var(--border);">
      <div class="flex justify-between items-center">
        <div class="text-[14px] font-light" style="color: var(--soft);">Fieldmarks is a <a href="https://mutomorro.com" target="_blank" rel="noopener" class="no-underline transition-colors duration-200 hover:!text-[var(--accent)]" style="color: var(--mid);">Mutomorro</a> project. Free and open.</div>
        <div class="text-[14px] font-light" style="color: var(--soft);">A sibling of <a href="https://moresapien.org" target="_blank" rel="noopener" class="no-underline transition-colors duration-200 hover:!text-[var(--accent)]" style="color: var(--mid);">Moresapien</a></div>
      </div>
    </footer>

  </body>
</html>

<style>
  @media (max-width: 768px) {
    nav { padding: 16px 24px !important; }
    footer { padding: 32px 24px !important; }
  }
  nav.scrolled {
    background: rgba(255,255,255,0.92) !important;
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    border-bottom: 1px solid var(--border);
  }
</style>

<script is:inline>
  const nav = document.getElementById('main-nav');
  window.addEventListener('scroll', () => {
    nav.classList.toggle('scrolled', window.scrollY > 80);
  });
</script>
