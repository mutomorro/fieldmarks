---
import Layout from '../layouts/Layout.astro';
import { getCollection } from 'astro:content';
import HeroGrid from '../components/HeroGrid.jsx';
import DotGrid from '../components/DotGrid.jsx';
import ThemeIcon from '../components/ThemeIcon.jsx';

// Get all entries and themes
const allEntries = await getCollection('entries', ({ data }) => !data.draft);
const allThemes = await getCollection('themes');
const themes = allThemes.sort((a, b) => a.data.order - b.data.order);

// Build a theme title lookup from slug
const themeTitleBySlug: Record<string, string> = {};
for (const t of themes) {
  themeTitleBySlug[t.slug] = t.data.title;
}
---

<Layout title="A field guide to systems thinking">

  <!-- ====== HERO ====== -->
  <section class="hero">
    <HeroGrid client:load />
    <div class="hero-content">
      <h1>A field guide to<br />systems thinking</h1>
      <p>How things connect. Why they behave the way they do. And where to find the leverage for change.</p>
      <a href="#discover" class="hero-cta">
        Start exploring
        <svg viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5" class="w-4 h-4 transition-transform duration-300">
          <path d="M8 3v10M4 9l4 4 4-4"/>
        </svg>
      </a>
    </div>
    <div class="scroll-hint"></div>
  </section>

  <!-- ====== DISCOVER ====== -->
  <section class="discover" id="discover">
    <div class="section-label">Explore</div>
    <h2 class="section-title">Every system tells<br />a story</h2>
    <p class="section-intro">Each concept comes with its own illustration - a dot-grid that shows what the idea does to a system. The healthy grid gets perturbed, and you can see the pattern.</p>

    <div class="concept-grid">
      {allEntries.map((entry) => (
        <a href={`/concept/${entry.slug}`} class="concept-card">
          <div class="card-illustration">
            {entry.data.dotGrid ? (
              <DotGrid
                seed={entry.data.dotGrid.seed}
                variant={entry.data.dotGrid.variant}
                width={380}
                height={237}
              />
            ) : (
              <DotGrid seed={42} variant="default" width={380} height={237} />
            )}
          </div>
          <div class="card-theme">{themeTitleBySlug[entry.data.theme] || entry.data.theme}</div>
          <div class="card-title">{entry.data.title}</div>
          <div class="card-oneliner">{entry.data.oneLiner}</div>
        </a>
      ))}
    </div>
  </section>

  <hr class="section-divider" />

  <!-- ====== THEMES ====== -->
  <section class="themes-section">
    <div class="section-label">Browse by theme</div>
    <h2 class="section-title">13 ways into<br />the territory</h2>
    <p class="section-intro">Systems thinking is a connected discipline. These themes are starting points, not boundaries - most concepts touch several.</p>

    <div class="theme-list">
      {themes.map((theme) => (
        <a href={`/theme/${theme.slug}`} class="theme-card">
          <div class="theme-icon">
            <ThemeIcon slug={theme.slug} />
          </div>
          <div class="theme-name">{theme.data.title}</div>
          <div class="theme-desc">{theme.data.subtitle}</div>
        </a>
      ))}
    </div>
  </section>

  <!-- ====== CONNECTIONS CTA ====== -->
  <section class="connections-cta">
    <div class="section-label">The map</div>
    <h2 class="section-title">See how everything connects</h2>
    <p class="section-intro">The interactive graph shows how every concept relates to every other - because the links between ideas are where the real insight lives.</p>
    <a href="/connections" class="cta-button">
      Explore the connections
      <svg width="16" height="16" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5">
        <path d="M3 8h10M9 4l4 4-4 4"/>
      </svg>
    </a>
  </section>

</Layout>

<style>
  /* ====== HERO ====== */
  .hero {
    position: relative;
    min-height: 100vh;
    background: var(--white);
    display: flex;
    flex-direction: column;
    justify-content: center;
    padding: 140px 48px 100px;
    overflow: hidden;
  }
  .hero-content {
    position: relative;
    z-index: 1;
    max-width: 680px;
  }
  .hero h1 {
    font-size: clamp(52px, 7vw, 84px);
    font-weight: 400;
    line-height: 1.05;
    color: var(--deep);
    margin-bottom: 28px;
    letter-spacing: -0.025em;
  }
  .hero p {
    font-size: clamp(18px, 2.2vw, 22px);
    font-weight: 300;
    line-height: 1.65;
    color: var(--soft);
    max-width: 500px;
    margin-bottom: 52px;
  }
  .hero-cta {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    font-size: 15px;
    font-weight: 400;
    color: var(--deep);
    text-decoration: none;
    border: 1px solid var(--border-hover);
    padding: 14px 28px;
    transition: all 0.3s;
  }
  .hero-cta:hover {
    border-color: var(--accent);
    color: var(--accent);
  }
  .hero-cta:hover svg {
    transform: translateY(4px);
  }

  .scroll-hint {
    position: absolute;
    bottom: 48px;
    left: 50%;
    transform: translateX(-50%);
    z-index: 1;
    width: 1px;
    height: 48px;
    background: linear-gradient(to bottom, var(--soft), transparent);
    opacity: 0.25;
    animation: pulse-down 2.5s ease-in-out infinite;
  }
  @keyframes pulse-down {
    0%, 100% { opacity: 0.15; }
    50% { opacity: 0.4; }
  }

  /* ====== SECTIONS ====== */
  section {
    padding: 140px 48px;
  }

  .section-divider {
    max-width: 1200px;
    margin: 0 auto;
    border: none;
    border-top: 1px solid var(--border);
  }

  .section-label {
    font-size: 12px;
    font-weight: 500;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--accent);
    margin-bottom: 24px;
  }
  .section-title {
    font-size: clamp(38px, 4.5vw, 60px);
    font-weight: 400;
    line-height: 1.12;
    color: var(--deep);
    margin-bottom: 20px;
    letter-spacing: -0.02em;
  }
  .section-intro {
    font-size: 19px;
    font-weight: 300;
    line-height: 1.7;
    color: var(--soft);
    max-width: 540px;
    margin-bottom: 80px;
  }

  /* ====== DISCOVER ====== */
  .discover {
    background: var(--white);
  }

  /* ====== CONCEPT CARDS ====== */
  .concept-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(360px, 1fr));
    gap: 48px 36px;
  }
  .concept-card {
    text-decoration: none;
    color: inherit;
    display: flex;
    flex-direction: column;
    transition: transform 0.3s ease;
  }
  .concept-card:hover {
    transform: translateY(-3px);
  }
  .card-illustration {
    width: 100%;
    aspect-ratio: 16 / 10;
    background: var(--warm-bg);
    margin-bottom: 24px;
    position: relative;
    overflow: hidden;
  }
  .card-theme {
    font-size: 12px;
    font-weight: 500;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--accent);
    margin-bottom: 10px;
  }
  .card-title {
    font-size: 28px;
    font-weight: 400;
    line-height: 1.2;
    color: var(--deep);
    margin-bottom: 10px;
    letter-spacing: -0.01em;
    transition: color 0.2s;
  }
  .concept-card:hover .card-title {
    color: var(--accent);
  }
  .card-oneliner {
    font-size: 16px;
    font-weight: 300;
    line-height: 1.65;
    color: var(--soft);
  }

  /* ====== THEMES ====== */
  .themes-section {
    background: var(--white);
  }
  .theme-list {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
    gap: 1px;
    background: var(--border);
    border: 1px solid var(--border);
  }
  .theme-card {
    padding: 36px;
    background: var(--white);
    text-decoration: none;
    color: inherit;
    transition: all 0.25s;
  }
  .theme-card:hover {
    background: var(--warm-bg);
  }
  .theme-icon {
    width: 40px;
    height: 40px;
    margin-bottom: 20px;
  }
  .theme-name {
    font-size: 19px;
    font-weight: 400;
    color: var(--deep);
    margin-bottom: 8px;
    line-height: 1.3;
    transition: color 0.2s;
  }
  .theme-card:hover .theme-name {
    color: var(--accent);
  }
  .theme-desc {
    font-size: 15px;
    font-weight: 300;
    line-height: 1.6;
    color: var(--soft);
  }

  /* ====== CONNECTIONS CTA ====== */
  .connections-cta {
    background: var(--warm-bg);
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
  }
  .connections-cta .section-intro {
    margin-left: auto;
    margin-right: auto;
    max-width: 500px;
  }
  .cta-button {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    font-size: 15px;
    font-weight: 400;
    color: var(--white);
    text-decoration: none;
    background: var(--deep);
    padding: 16px 36px;
    transition: all 0.3s;
  }
  .cta-button:hover {
    background: var(--accent);
    transform: translateY(-2px);
  }

  /* ====== RESPONSIVE ====== */
  @media (max-width: 768px) {
    .hero { padding: 100px 24px 60px; }
    section { padding: 80px 24px; }
    .concept-grid { grid-template-columns: 1fr; gap: 40px; }
    .theme-list { grid-template-columns: 1fr; }
  }
</style>
