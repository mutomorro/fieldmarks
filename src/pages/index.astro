---
import Layout from '../layouts/Layout.astro';
import { getCollection } from 'astro:content';
import HeroGrid from '../components/HeroGrid.jsx';
import DotGrid from '../components/DotGrid.jsx';
import ThemeIcon from '../components/ThemeIcon.jsx';

// Get all entries and themes
const allEntries = await getCollection('entries', ({ data }) => !data.draft);
const allThemes = await getCollection('themes');
const themes = allThemes.sort((a, b) => a.data.order - b.data.order);

// Build a theme title lookup from slug
const themeTitleBySlug: Record<string, string> = {};
for (const t of themes) {
  themeTitleBySlug[t.slug] = t.data.title;
}
---

<Layout title="A field guide to systems thinking">

  <!-- ====== HERO ====== -->
  <section class="hero">
    <div data-hero-grid class="hero-grid-wrapper">
      <HeroGrid client:load />
    </div>
    <div class="hero-content">
      <h1>A field guide to<br />systems thinking</h1>
      <p>How things connect. Why they behave the way they do. And where to find the leverage for change.</p>
      <a href="#discover" class="hero-cta">
        Start exploring
        <svg viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5" class="w-4 h-4 transition-transform duration-300">
          <path d="M8 3v10M4 9l4 4 4-4"/>
        </svg>
      </a>
    </div>
    <div class="scroll-hint"></div>
  </section>

  <hr class="section-divider" />

  <!-- ====== DISCOVER ====== -->
  <section class="discover" id="discover">
    <div class="section-label">Explore</div>
    <h2 class="section-title">Every system tells<br />a story</h2>
    <p class="section-intro">Systems behave in patterns - and once you can name them, you start seeing them everywhere. Each concept here is a building block for understanding how things connect, why they resist change, and where to find the leverage.</p>

    <div class="concept-grid">
      {allEntries.map((entry) => (
        <a href={`/concept/${entry.slug}`} class="concept-card">
          <div class="card-illustration">
            {entry.data.dotGrid ? (
              <DotGrid
                seed={entry.data.dotGrid.seed}
                variant={entry.data.dotGrid.variant}
                width={380}
                height={237}
              />
            ) : (
              <DotGrid seed={42} variant="default" width={380} height={237} />
            )}
          </div>
          <div class="card-theme">{themeTitleBySlug[entry.data.theme] || entry.data.theme}</div>
          <div class="card-title">{entry.data.title}</div>
          <div class="card-oneliner">{entry.data.oneLiner}</div>
        </a>
      ))}
    </div>
  </section>

  <hr class="section-divider" />

  <!-- ====== THEMES ====== -->
  <section class="themes-section">
    <div class="section-label">Browse by theme</div>
    <h2 class="section-title">13 ways into<br />the territory</h2>
    <p class="section-intro">Systems thinking is a connected discipline. These themes are starting points, not boundaries - most concepts touch several.</p>

    <div class="theme-grid">
      {themes.map((theme) => (
        <a href={`/theme/${theme.slug}`} class="theme-card">
          <div class="theme-icon">
            <ThemeIcon slug={theme.slug} />
          </div>
          <div class="theme-name">{theme.data.title}</div>
          <div class="theme-desc">{theme.data.subtitle}</div>
        </a>
      ))}
    </div>
  </section>

  <hr class="section-divider" />

  <!-- ====== CONNECTIONS CTA ====== -->
  <section class="connections-cta">
    <div class="section-label connections-label">The map</div>
    <h2 class="section-title connections-title">See how everything connects</h2>
    <p class="section-intro connections-intro">The interactive graph shows how every concept relates to every other - because the links between ideas are where the real insight lives.</p>
    <a href="/connections" class="cta-button">
      Explore the connections
      <svg width="16" height="16" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5">
        <path d="M3 8h10M9 4l4 4-4 4"/>
      </svg>
    </a>
  </section>

</Layout>

<style>
  /* ====== HERO GRID WRAPPER ====== */
  .hero-grid-wrapper,
  .hero-grid-wrapper > * {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
  }

  /* ====== HERO ====== */
  .hero {
    position: relative;
    min-height: 100vh;
    background: var(--white);
    display: flex;
    flex-direction: column;
    justify-content: center;
    padding: 140px 48px 100px;
    overflow: hidden;
  }
  .hero-content {
    position: relative;
    z-index: 1;
    max-width: 680px;
  }
  .hero h1 {
    font-size: clamp(52px, 7vw, 84px);
    font-weight: 400;
    line-height: 1.05;
    color: var(--deep);
    margin-bottom: 28px;
    letter-spacing: -0.015em;
  }
  .hero p {
    font-size: clamp(18px, 2.2vw, 22px);
    font-weight: 400;
    line-height: 1.65;
    color: var(--soft);
    max-width: 500px;
    margin-bottom: 52px;
  }
  .hero-cta {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    font-size: 15px;
    font-weight: 400;
    color: var(--deep);
    text-decoration: none;
    border-width: 1px;
    border-style: solid;
    border-color: rgba(34, 28, 43, 0.18);
    padding: 14px 28px;
    transition: all 0.2s ease;
  }
  .hero-cta:hover {
    border-color: var(--accent);
    color: var(--accent);
  }
  .hero-cta:hover svg {
    transform: translateY(4px);
  }

  .scroll-hint {
    position: absolute;
    bottom: 48px;
    left: 50%;
    transform: translateX(-50%);
    z-index: 1;
    width: 1px;
    height: 48px;
    background: linear-gradient(to bottom, var(--soft), transparent);
    opacity: 0.25;
    animation: pulse-down 2.5s ease-in-out infinite;
  }
  @keyframes pulse-down {
    0%, 100% { opacity: 0.15; }
    50% { opacity: 0.4; }
  }

  /* ====== SECTIONS ====== */
  section {
    padding: 140px 48px;
  }

  .section-divider {
    max-width: 1200px;
    margin: 0 auto;
    border: none;
    border-top: 1px solid var(--border);
  }

  .section-label {
    font-size: 12px;
    font-weight: 500;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--accent);
    margin-bottom: 24px;
  }
  .section-title {
    font-size: clamp(38px, 4.5vw, 60px);
    font-weight: 400;
    line-height: 1.12;
    color: var(--deep);
    margin-bottom: 20px;
    letter-spacing: -0.01em;
  }
  .section-intro {
    font-size: 19px;
    font-weight: 400;
    line-height: 1.7;
    color: var(--soft);
    max-width: 540px;
    margin-bottom: 80px;
  }

  /* ====== DISCOVER ====== */
  .discover {
    background-color: var(--white);
  }

  /* ====== CONCEPT CARDS ====== */
  .concept-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(360px, 1fr));
    gap: 48px 36px;
  }
  .concept-card {
    text-decoration: none;
    color: inherit;
    display: flex;
    flex-direction: column;
    border-width: 1px;
    border-style: solid;
    border-color: rgba(34, 28, 43, 0.1);
    background-color: #FFFFFF;
    padding: 0 0 20px 0;
    transition: transform 0.2s ease, border-color 0.2s ease, box-shadow 0.2s ease;
  }
  .concept-card:hover {
    transform: translateY(-3px);
    border-color: var(--accent);
    box-shadow: 0 4px 12px rgba(34, 28, 43, 0.06);
  }
  .card-illustration {
    width: 100%;
    aspect-ratio: 16 / 10;
    background-color: var(--warm-bg);
    margin-bottom: 20px;
    padding: 20px;
    position: relative;
    overflow: hidden;
  }
  .card-theme {
    align-self: flex-start;
    font-size: 10px;
    font-weight: 500;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--accent);
    background-color: rgba(155, 81, 224, 0.08);
    padding: 4px 9px;
    margin: 0 20px 10px;
  }
  .card-title {
    font-size: 31px;
    font-weight: 400;
    line-height: 1.2;
    color: var(--deep);
    margin-bottom: 10px;
    letter-spacing: -0.005em;
    transition: color 0.2s;
    padding: 0 20px;
  }
  .concept-card:hover .card-title {
    color: var(--accent);
  }
  .card-oneliner {
    font-size: 16px;
    font-weight: 400;
    line-height: 1.65;
    color: var(--soft);
    padding: 0 20px;
  }

  /* ====== THEMES ====== */
  .themes-section {
    background: var(--white);
  }
  .theme-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
    gap: 20px;
  }
  .theme-card {
    padding: 36px;
    background: var(--warm-bg);
    text-decoration: none;
    color: inherit;
    border: 1px solid rgba(34, 28, 43, 0.1);
    transition: transform 0.2s ease, border-color 0.2s ease, box-shadow 0.2s ease;
  }
  .theme-card:hover {
    transform: translateY(-3px);
    border-color: var(--accent);
    box-shadow: 0 4px 12px rgba(34, 28, 43, 0.06);
  }
  .theme-icon {
    width: 40px;
    height: 40px;
    margin-bottom: 20px;
  }
  .theme-name {
    font-size: 19px;
    font-weight: 400;
    color: var(--deep);
    margin-bottom: 8px;
    line-height: 1.3;
    transition: color 0.2s;
  }
  .theme-card:hover .theme-name {
    color: var(--accent);
  }
  .theme-desc {
    font-size: 15px;
    font-weight: 400;
    line-height: 1.6;
    color: var(--soft);
  }

  /* ====== CONNECTIONS CTA ====== */
  .connections-cta {
    background-color: var(--white);
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
  }
  .connections-label {
    color: var(--accent);
  }
  .connections-title {
    color: var(--deep);
  }
  .connections-intro {
    color: var(--soft);
    margin-left: auto;
    margin-right: auto;
    max-width: 500px;
  }
  .cta-button {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    font-size: 15px;
    font-weight: 400;
    color: var(--deep);
    text-decoration: none;
    background-color: transparent;
    border-width: 1px;
    border-style: solid;
    border-color: rgba(34, 28, 43, 0.18);
    padding: 16px 36px;
    transition: all 0.2s ease;
  }
  .cta-button:hover {
    border-color: var(--accent);
    color: var(--accent);
    transform: translateY(-2px);
  }

  /* ====== RESPONSIVE ====== */
  @media (max-width: 768px) {
    .hero { padding: 100px 24px 60px; }
    section { padding: 80px 24px; }
    .concept-grid { grid-template-columns: 1fr; gap: 40px; }
    .theme-grid { grid-template-columns: 1fr; }
  }
</style>
