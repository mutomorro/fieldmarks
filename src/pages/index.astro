---
import Layout from '../layouts/Layout.astro';
import { getCollection } from 'astro:content';

// Get all entries and themes
const allEntries = await getCollection('entries', ({ data }) => !data.draft);
const allThemes = await getCollection('themes');

// Sort themes by order
const themes = allThemes.sort((a, b) => a.data.order - b.data.order);

// Group entries by theme
const entriesByTheme: Record<string, typeof allEntries> = {};
for (const entry of allEntries) {
  const theme = entry.data.theme;
  if (!entriesByTheme[theme]) entriesByTheme[theme] = [];
  entriesByTheme[theme].push(entry);
}

// Count total connections from graph data
const totalConnections = allEntries.reduce((sum, e) => sum + e.data.related.length, 0);
const themesWithEntries = themes.filter(t => (entriesByTheme[t.slug] || []).length > 0);
const themesEmpty = themes.filter(t => (entriesByTheme[t.slug] || []).length === 0);
---

<Layout title="A field guide to systems thinking">
  <div class="max-w-content mx-auto px-6 md:px-12">

    <!-- Hero -->
    <div class="pt-16 md:pt-24 pb-12 md:pb-16 relative">
      <div class="max-w-2xl">
        <h1 class="text-[42px] md:text-[52px] font-normal leading-[1.1] mb-5 text-mt-deep">
          A field guide to<br />systems thinking
        </h1>
        <p class="text-[18px] md:text-[20px] font-light text-mt-mid leading-relaxed mb-8">
          Practical concepts for people who work in organisations. How things connect, why they behave the way they do, and where to find the leverage for change.
        </p>

        <!-- Stats -->
        <div class="flex items-center gap-6 text-[13px] font-normal text-mt-mid/50">
          <span>{allEntries.length} concepts</span>
          <span class="w-1 h-1 bg-mt-mid/20 inline-block"></span>
          <span>{totalConnections} connections</span>
          <span class="w-1 h-1 bg-mt-mid/20 inline-block"></span>
          <span>{themes.length} themes</span>
          <span class="w-1 h-1 bg-mt-mid/20 inline-block"></span>
          <span>Growing weekly</span>
        </div>
      </div>

      <!-- Decorative dot-grid mark, large, top right -->
      <div class="hidden lg:block absolute top-16 right-0 opacity-[0.06]" aria-hidden="true">
        <svg width="280" height="280" viewBox="0 0 30 30">
          <rect x="0" y="0" width="6" height="6" fill="#221C2B"/>
          <rect x="12" y="0" width="6" height="6" fill="#221C2B"/>
          <rect x="24" y="0" width="6" height="6" fill="#221C2B"/>
          <rect x="0" y="12" width="6" height="6" fill="#221C2B"/>
          <rect x="14" y="14" width="6" height="6" fill="#9B51E0"/>
          <rect x="24" y="12" width="6" height="6" fill="#221C2B"/>
          <rect x="0" y="24" width="6" height="6" fill="#221C2B"/>
          <rect x="12" y="24" width="6" height="6" fill="#221C2B"/>
          <rect x="24" y="24" width="6" height="6" fill="#221C2B"/>
        </svg>
      </div>
    </div>

    <!-- Divider -->
    <div class="border-t border-mt-deep/8 mb-10"></div>

    <!-- Toggle -->
    <div class="flex items-center justify-between mb-10">
      <div class="flex">
        <button
          id="btn-list"
          class="px-5 py-2 text-[13px] font-normal border border-mt-deep/20 bg-mt-deep text-white cursor-pointer transition-all"
          onclick="switchView('list')"
        >
          Browse by theme
        </button>
        <button
          id="btn-graph"
          class="px-5 py-2 text-[13px] font-normal border border-mt-deep/10 border-l-0 bg-transparent text-mt-mid cursor-pointer transition-all hover:bg-mt-cream/50"
          onclick="switchView('graph')"
        >
          See connections
        </button>
      </div>
      <p class="text-[13px] text-mt-mid/40 hidden md:block">
        {themesWithEntries.length} of {themes.length} themes started
      </p>
    </div>

    <!-- LIST VIEW -->
    <div id="view-list">

      <!-- Themes with entries -->
      {themesWithEntries.map((theme) => {
        const themeEntries = entriesByTheme[theme.slug] || [];
        return (
          <div class="mb-14">
            <!-- Theme header with colour accent -->
            <div class="flex items-start gap-4 mb-5">
              <div class="w-1 self-stretch mt-1 flex-shrink-0" style={`background: ${theme.data.colour}`}></div>
              <div class="flex-1">
                <div class="flex items-baseline gap-3 mb-1">
                  <h2 class="text-[24px] font-normal">
                    <a href={`/theme/${theme.slug}`} class="hover:text-mt-accent transition-colors">
                      {theme.data.title}
                    </a>
                  </h2>
                  <span class="text-[13px] text-mt-mid/40">{themeEntries.length} concept{themeEntries.length !== 1 ? 's' : ''}</span>
                </div>
                <p class="text-[15px] font-light text-mt-mid/70 leading-relaxed max-w-xl">
                  {theme.data.subtitle}
                </p>
              </div>
            </div>

            <!-- Entry cards -->
            <div class="grid grid-cols-1 md:grid-cols-2 gap-3 ml-5">
              {themeEntries.map((entry) => (
                <a
                  href={`/concept/${entry.slug}`}
                  class="block p-4 border border-mt-deep/6 hover:border-mt-deep/15 transition-all group bg-white hover:bg-mt-cream/20"
                >
                  <div class="flex items-start gap-3">
                    <span class="w-1.5 h-1.5 mt-2 flex-shrink-0 inline-block" style={`background: ${theme.data.colour}`}></span>
                    <div>
                      <p class="text-[16px] font-normal mb-1 group-hover:text-mt-accent transition-colors">
                        {entry.data.title}
                      </p>
                      <p class="text-[14px] font-light text-mt-mid/70 leading-snug">
                        {entry.data.oneLiner}
                      </p>
                    </div>
                  </div>
                </a>
              ))}
            </div>

            {themeEntries.length > 4 && (
              <a href={`/theme/${theme.slug}`} class="text-[13px] text-mt-accent mt-3 ml-5 inline-block hover:underline">
                See all {themeEntries.length} &rarr;
              </a>
            )}
          </div>
        );
      })}

      <!-- Coming soon themes -->
      {themesEmpty.length > 0 && (
        <div class="mt-8 pt-8 border-t border-mt-deep/6">
          <p class="text-[13px] font-normal text-mt-mid/40 uppercase tracking-[0.15em] mb-6">Coming soon</p>
          <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">
            {themesEmpty.map((theme) => (
              <div class="p-4 border border-mt-deep/4 bg-mt-cream/15">
                <div class="flex items-center gap-2.5 mb-1.5">
                  <span class="w-2 h-2 inline-block flex-shrink-0" style={`background: ${theme.data.colour}; opacity: 0.6`}></span>
                  <p class="text-[15px] font-normal text-mt-deep/60">
                    {theme.data.title}
                  </p>
                </div>
                <p class="text-[13px] font-light text-mt-mid/40 leading-snug">
                  {theme.data.subtitle}
                </p>
              </div>
            ))}
          </div>
        </div>
      )}

    </div>

    <!-- GRAPH VIEW -->
    <div id="view-graph" class="hidden">
      <div class="border border-mt-deep/10 bg-mt-deep h-[500px] md:h-[600px] flex items-center justify-center relative">
        <!-- Graph component will be mounted here -->
        <div id="graph-container" class="w-full h-full flex items-center justify-center">
          <div class="text-center">
            <p class="text-[16px] text-white/40 mb-2">
              Connection map
            </p>
            <p class="text-[13px] text-white/25">
              {allEntries.length} concepts across {themes.length} themes
            </p>
          </div>
        </div>
        <div class="absolute bottom-4 left-5 text-[12px] text-white/25">
          Drag to explore. Click a node to open the concept.
        </div>
        <div class="absolute bottom-4 right-5 text-[12px] text-white/25">
          {allEntries.length} concepts, {totalConnections} connections
        </div>
      </div>

      <!-- Theme legend -->
      <div class="flex flex-wrap gap-4 mt-4">
        {themes.map((theme) => {
          const count = (entriesByTheme[theme.slug] || []).length;
          return count > 0 ? (
            <span class="flex items-center gap-1.5 text-[12px] text-mt-mid/60">
              <span class="w-2 h-2 inline-block" style={`background: ${theme.data.colour}`}></span>
              {theme.data.title}
              <span class="text-mt-mid/30">{count}</span>
            </span>
          ) : null;
        })}
      </div>
    </div>

  </div>

  <!-- Bottom CTA band -->
  <div class="bg-mt-cream/40 border-t border-mt-deep/6 mt-20">
    <div class="max-w-content mx-auto px-6 md:px-12 py-12 md:py-16">
      <div class="max-w-xl">
        <h2 class="text-[24px] font-normal mb-3">This is a living resource</h2>
        <p class="text-[16px] font-light text-mt-mid/70 leading-relaxed mb-4">
          Fieldmarks is growing every week. New concepts, new connections, new themes. It's built by Mutomorro as a free, open resource for anyone who wants to understand how things really work - and where to find the leverage for change.
        </p>
        <a href="/about" class="text-[14px] font-normal text-mt-accent hover:underline">
          About this project &rarr;
        </a>
      </div>
    </div>
  </div>
</Layout>

<script is:inline>
  function switchView(view) {
    const listEl = document.getElementById('view-list');
    const graphEl = document.getElementById('view-graph');
    const btnList = document.getElementById('btn-list');
    const btnGraph = document.getElementById('btn-graph');

    if (view === 'list') {
      listEl.classList.remove('hidden');
      graphEl.classList.add('hidden');
      btnList.className = 'px-5 py-2 text-[13px] font-normal border border-mt-deep/20 bg-mt-deep text-white cursor-pointer transition-all';
      btnGraph.className = 'px-5 py-2 text-[13px] font-normal border border-mt-deep/10 border-l-0 bg-transparent text-mt-mid cursor-pointer transition-all hover:bg-mt-cream/50';
      history.replaceState(null, '', '/');
    } else {
      listEl.classList.add('hidden');
      graphEl.classList.remove('hidden');
      btnGraph.className = 'px-5 py-2 text-[13px] font-normal border border-mt-deep/20 bg-mt-deep text-white cursor-pointer transition-all';
      btnList.className = 'px-5 py-2 text-[13px] font-normal border border-mt-deep/10 border-r-0 bg-transparent text-mt-mid cursor-pointer transition-all hover:bg-mt-cream/50';
      history.replaceState(null, '', '/?view=graph');
    }
  }

  // Check URL on load
  if (window.location.search.includes('view=graph')) {
    switchView('graph');
  }
</script>
