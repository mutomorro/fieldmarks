---
import Layout from '../layouts/Layout.astro';
import ConnectionGraph from '../components/ConnectionGraph.jsx';
---

<Layout title="Connections" description="Explore the web of systems thinking concepts" transparentNav={true}>
  <div class="connections-page">
    <ConnectionGraph client:only="react" />
  </div>
</Layout>

<style>
  .connections-page {
    position: fixed;
    inset: 0;
    width: 100vw;
    height: 100vh;
    overflow: hidden;
    background: radial-gradient(ellipse at 50% 50%, #2a2435 0%, #1a1525 40%, #110f18 100%);
  }
</style>

<style is:global>
  /* Prevent scroll on connections page */
  .transparent-nav-page {
    overflow: hidden;
    height: 100vh;
  }
</style>
