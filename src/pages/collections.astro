---
import Layout from '../layouts/Layout.astro';
import { getCollection } from 'astro:content';

const allCollections = await getCollection('collections');
const sortedCollections = allCollections.sort((a, b) => a.data.order - b.data.order);

// Resolve entry slugs to titles
const allEntries = await getCollection('entries');
const entryTitleBySlug: Record<string, string> = {};
for (const e of allEntries) {
  entryTitleBySlug[e.slug] = e.data.title;
}
---

<Layout title="Collections" description="Guided pathways through systems thinking concepts, each framed around a recognisable situation.">
  <div class="max-w-content mx-auto px-6 md:px-12">

    <!-- Breadcrumb -->
    <div class="pt-24">
      <div class="breadcrumb">
        <a href="/">Home</a>
        <span>/</span>
        <span class="current">Collections</span>
      </div>
    </div>

    <!-- Header -->
    <div class="page-header">
      <h1>Collections</h1>
      <p class="page-subtitle">Each pathway starts from something you might recognise - a recurring challenge, a pattern that won't shift, a situation that doesn't respond to the usual approaches. Pick the one that sounds familiar.</p>
    </div>

    <!-- Collection cards -->
    <div class="collections-list">
      {sortedCollections.map((col) => (
        <a href={`/collection/${col.slug}`} class="collection-card">
          <div class="card-col card-challenge">
            <div class="col-label">The challenge</div>
            <h2 class="challenge-title">{col.data.title}</h2>
          </div>
          <div class="card-divider"></div>
          <div class="card-col card-pattern">
            <div class="col-label">The pattern</div>
            <p class="pattern-text">{col.data.subtitle}</p>
          </div>
          <div class="card-divider"></div>
          <div class="card-col card-pathway">
            <div class="col-label">The pathway</div>
            <ul class="pathway-list">
              {col.data.entries.map(step => (
                <li>
                  <span class="pathway-dot"></span>
                  {entryTitleBySlug[step.slug] || step.slug}
                </li>
              ))}
            </ul>
            <span class="pathway-start">Start this pathway &rarr;</span>
          </div>
        </a>
      ))}
    </div>

  </div>
</Layout>

<style>
  .breadcrumb {
    display: flex;
    align-items: center;
    gap: 8px;
    font-size: 14px;
    color: var(--soft);
    margin-bottom: 48px;
  }
  .breadcrumb a {
    color: var(--soft);
    text-decoration: none;
    transition: color 0.2s;
  }
  .breadcrumb a:hover {
    color: var(--accent);
  }
  .breadcrumb .current {
    color: var(--mid);
  }

  .page-header {
    margin-bottom: 48px;
    max-width: 680px;
  }
  .page-header h1 {
    font-size: clamp(38px, 4.5vw, 52px);
    font-weight: 400;
    line-height: 1.12;
    color: var(--deep);
    margin-bottom: 16px;
    letter-spacing: -0.015em;
  }
  .page-subtitle {
    font-size: 20px;
    font-weight: 400;
    line-height: 1.65;
    color: var(--soft);
  }

  /* ====== COLLECTION CARDS ====== */
  .collections-list {
    display: flex;
    flex-direction: column;
    gap: 24px;
    margin-bottom: 120px;
  }

  .collection-card {
    display: grid;
    grid-template-columns: 1fr auto 1.2fr auto 1fr;
    border: 0.5px solid var(--border);
    border-radius: 8px !important;
    text-decoration: none;
    color: inherit;
    transition: border-color 0.2s ease;
    overflow: hidden;
  }
  .collection-card:hover {
    border-color: var(--accent);
  }

  .card-col {
    padding: 24px;
  }

  .card-divider {
    width: 0.5px;
    background: var(--border);
    align-self: stretch;
  }

  .col-label {
    font-size: 10px;
    font-weight: 500;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--soft);
    margin-bottom: 16px;
  }

  /* Challenge column */
  .challenge-title {
    font-size: 22px;
    font-weight: 400;
    color: var(--deep);
    line-height: 1.25;
    transition: color 0.2s;
  }
  .collection-card:hover .challenge-title {
    color: var(--accent);
  }

  /* Pattern column */
  .pattern-text {
    font-size: 15px;
    font-weight: 400;
    line-height: 1.6;
    color: var(--soft);
    margin: 0;
  }

  /* Pathway column */
  .pathway-list {
    list-style: none;
    padding: 0;
    margin: 0 0 16px 0;
    display: flex;
    flex-direction: column;
    gap: 6px;
  }
  .pathway-list li {
    display: flex;
    align-items: center;
    gap: 8px;
    font-size: 13px;
    font-weight: 400;
    color: var(--deep);
  }
  .pathway-dot {
    width: 5px;
    height: 5px;
    background: var(--accent);
    flex-shrink: 0;
  }
  .pathway-start {
    font-size: 13px;
    font-weight: 500;
    color: var(--accent);
  }

  /* ====== MOBILE ====== */
  @media (max-width: 768px) {
    .collection-card {
      grid-template-columns: 1fr;
      grid-template-rows: auto;
    }
    .card-divider {
      width: 100%;
      height: 0.5px;
    }
  }
</style>
