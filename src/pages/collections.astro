---
import Layout from '../layouts/Layout.astro';
import { getCollection } from 'astro:content';

const allCollections = await getCollection('collections');
const sortedCollections = allCollections.sort((a, b) => a.data.order - b.data.order);
---

<Layout title="Collections" description="Guided pathways through systems thinking concepts, each framed around a recognisable situation.">
  <div class="max-w-content mx-auto px-6 md:px-12">

    <!-- Breadcrumb -->
    <div class="pt-24">
      <div class="breadcrumb">
        <a href="/">Home</a>
        <span>/</span>
        <span class="current">Collections</span>
      </div>
    </div>

    <!-- Header -->
    <div class="page-header">
      <h1>Collections</h1>
      <p class="page-subtitle">Guided pathways through systems thinking concepts, each framed around a recognisable situation.</p>
    </div>

    <!-- Collections grid -->
    <div class="collections-grid">
      {sortedCollections.map((col) => (
        <a href={`/collection/${col.slug}`} class="collection-card">
          <h2 class="collection-title">{col.data.title}</h2>
          <p class="collection-subtitle">{col.data.subtitle}</p>
          <span class="collection-count">
            {col.data.entries.length} concepts →
          </span>
        </a>
      ))}
    </div>

  </div>
</Layout>

<style>
  .breadcrumb {
    display: flex;
    align-items: center;
    gap: 8px;
    font-size: 14px;
    color: var(--soft);
    margin-bottom: 48px;
  }
  .breadcrumb a {
    color: var(--soft);
    text-decoration: none;
    transition: color 0.2s;
  }
  .breadcrumb a:hover {
    color: var(--accent);
  }
  .breadcrumb .current {
    color: var(--mid);
  }

  .page-header {
    margin-bottom: 48px;
    max-width: 680px;
  }
  .page-header h1 {
    font-size: clamp(38px, 4.5vw, 52px);
    font-weight: 400;
    line-height: 1.12;
    color: var(--deep);
    margin-bottom: 16px;
    letter-spacing: -0.015em;
  }
  .page-subtitle {
    font-size: 20px;
    font-weight: 400;
    line-height: 1.65;
    color: var(--soft);
  }

  .collections-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 24px;
    margin-bottom: 120px;
  }

  .collection-card {
    display: block;
    padding: 36px;
    border: 1px solid var(--border);
    text-decoration: none;
    color: inherit;
    transition: border-color 0.2s ease, background-color 0.2s ease;
  }

  .collection-card:hover {
    border-color: var(--border-hover);
    background-color: var(--warm-bg);
  }

  .collection-title {
    font-size: 24px;
    font-weight: 400;
    color: var(--deep);
    margin-bottom: 8px;
    transition: color 0.2s;
  }

  .collection-card:hover .collection-title {
    color: var(--accent);
  }

  .collection-subtitle {
    font-size: 16px;
    font-weight: 400;
    line-height: 1.6;
    color: var(--soft);
    margin-bottom: 12px;
  }

  .collection-count {
    font-size: 13px;
    font-weight: 500;
    color: var(--accent);
  }

  @media (max-width: 768px) {
    .collections-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
