---
import Layout from '../../layouts/Layout.astro';
import { getCollection } from 'astro:content';
import DotGrid from '../../components/DotGrid.jsx';

export async function getStaticPaths() {
  const entries = await getCollection('entries');
  return entries.map((entry) => ({
    params: { slug: entry.slug },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await entry.render();

// Get all entries for resolving related concepts
const allEntries = await getCollection('entries');
const entryMap = Object.fromEntries(allEntries.map(e => [e.slug, e]));

// Theme metadata
const themes = await getCollection('themes');
const theme = themes.find(t => t.slug === entry.data.theme);
---

<Layout title={entry.data.title} description={entry.data.oneLiner}>
  <div class="max-w-content mx-auto px-6 md:px-12">

    <!-- Breadcrumb -->
    <div class="pt-24">
      <div class="flex items-center gap-2 text-[14px] text-mt-mid/50 mb-8">
        <a href="/" class="hover:text-mt-accent transition-colors">Home</a>
        <span>/</span>
        {theme && (
          <>
            <a href={`/theme/${theme.slug}`} class="hover:text-mt-accent transition-colors">
              {theme.data.title}
            </a>
            <span>/</span>
          </>
        )}
        <span class="text-mt-mid/80">{entry.data.title}</span>
      </div>
    </div>

    <!-- Hero: text left, dot-grid right -->
    <div class="flex flex-col md:flex-row gap-8 md:gap-12 items-start mb-12">

      <!-- Text side -->
      <div class="flex-1 min-w-0">
        <!-- Kicker -->
        {theme && (
          <p class="kicker mb-3" style={`color: ${theme.data.colour}`}>
            {theme.data.title}
          </p>
        )}

        <!-- Title -->
        <h1 class="font-normal leading-[1.1] mb-5" style="color: var(--deep); font-size: clamp(44px, 5.5vw, 60px);">
          {entry.data.title}
        </h1>

        <!-- One-liner -->
        <p class="text-[20px] leading-relaxed" style="color: var(--soft);">
          {entry.data.oneLiner}
        </p>

        <!-- Also known as -->
        {entry.data.alsoKnownAs && entry.data.alsoKnownAs.length > 0 && (
          <p class="text-[14px] text-mt-mid/50 mt-4">
            Also known as: {entry.data.alsoKnownAs.join(', ')}
          </p>
        )}

        <!-- Attribution -->
        {entry.data.originatedBy && (
          <p class="text-[14px] text-mt-mid/50 mt-1">
            Originated by {entry.data.originatedBy}
          </p>
        )}
      </div>

      <!-- Dot-grid illustration -->
      <div class="w-full md:w-[320px] lg:w-[380px] flex-shrink-0">
        <div class="w-full aspect-[4/3]">
          <DotGrid
            client:load
            seed={entry.data.dotGrid?.seed || 42}
            variant={entry.data.dotGrid?.variant || 'default'}
          />
        </div>
      </div>

    </div>

    <!-- Divider -->
    <div class="border-t border-mt-deep/8 mb-12"></div>

    <!-- Content + ToC -->
    <div class="content-toc-wrapper">

      <!-- Main content -->
      <div class="flex-1 min-w-0 max-w-prose">
        <article class="prose prose-mt" id="entry-content">
          <Content />
        </article>
      </div>

      <!-- Sticky ToC (desktop only) -->
      <nav
        class="toc-sidebar"
        id="entry-toc"
        aria-label="Table of contents"
      >
        <ul></ul>
      </nav>

    </div>

    <!-- Related concepts -->
    {entry.data.related.length > 0 && (
      <div class="max-w-prose mt-16 pt-8 border-t border-mt-deep/10">
        <h2 class="text-[24px] font-normal mb-4">Connected concepts</h2>
        <div class="space-y-3">
          {entry.data.related.map((rel) => {
            const relatedEntry = entryMap[rel.slug];
            if (!relatedEntry) return null;
            const relTheme = themes.find(t => t.slug === relatedEntry.data.theme);
            return (
              <a
                href={`/concept/${rel.slug}`}
                class="block p-3 border border-mt-deep/8 hover:border-mt-deep/20 transition-colors group"
              >
                <div class="flex items-baseline gap-2 mb-0.5">
                  <span class="w-2 h-2 inline-block flex-shrink-0 mt-1" style={`background: ${relTheme?.data.colour || '#9B51E0'}`}></span>
                  <span class="text-[16px] font-normal group-hover:text-mt-accent transition-colors">
                    {relatedEntry.data.title}
                  </span>
                </div>
                {rel.note && (
                  <p class="text-[14px] font-light text-mt-mid/60 leading-snug ml-4">
                    {rel.note}
                  </p>
                )}
              </a>
            );
          })}
        </div>
      </div>
    )}

    <!-- Tags -->
    {entry.data.tags.length > 0 && (
      <div class="max-w-prose mt-8 pb-12">
        <div class="flex flex-wrap gap-2">
          {entry.data.tags.map((tag) => (
            <span class="text-[12px] text-mt-mid/40 border border-mt-deep/8 px-2 py-0.5 font-normal">
              {tag}
            </span>
          ))}
        </div>
      </div>
    )}

  </div>
</Layout>

<style>
  /* Content + ToC layout */
  .content-toc-wrapper {
    display: flex;
    gap: 3rem;
    align-items: flex-start;
  }
  .toc-sidebar {
    display: none;
    width: 180px;
    flex-shrink: 0;
    position: sticky;
    top: 7rem;
  }
  @media (min-width: 1024px) {
    .toc-sidebar { display: block; }
  }

  /* Prose styling for concept entries */
  .prose-mt :global(h2) {
    font-size: 36px;
    font-weight: 400;
    margin-top: 2.5rem;
    margin-bottom: 0.75rem;
    color: var(--deep);
  }

  .prose-mt :global(h3) {
    font-size: 26px;
    font-weight: 400;
    margin-top: 2rem;
    margin-bottom: 0.5rem;
    color: var(--deep);
  }

  .prose-mt :global(p) {
    font-size: 18px;
    font-weight: 400;
    line-height: 1.75;
    margin-bottom: 1.25rem;
    color: #3D3D3D;
  }

  .prose-mt :global(strong) {
    font-weight: 600;
    color: var(--deep);
  }

  .prose-mt :global(ul), .prose-mt :global(ol) {
    margin-bottom: 1.25rem;
    padding-left: 1.5rem;
  }

  .prose-mt :global(li) {
    font-size: 18px;
    font-weight: 400;
    line-height: 1.75;
    margin-bottom: 0.25rem;
    color: #3D3D3D;
  }

  .prose-mt :global(blockquote) {
    font-size: 24px;
    font-weight: 300;
    line-height: 1.5;
    color: #423B49;
    border-left: 3px solid #9B51E0;
    padding-left: 20px;
    margin: 2rem 0;
  }

  /* Kicker labels above section titles */
  .prose-mt :global(.kicker) {
    display: block;
    font-size: 12px;
    font-weight: 500;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: #9B51E0;
  }

  /* The wrapping <p> around the kicker controls spacing */
  .prose-mt :global(p:has(.kicker)) {
    margin-top: 3rem;
    margin-bottom: 0.5rem;
  }

  .prose-mt :global(p:has(.kicker)) + :global(h2) {
    margin-top: 0;
  }

  /* First kicker paragraph has no top margin */
  .prose-mt > :global(p:first-child:has(.kicker)) {
    margin-top: 0;
  }
</style>

<style is:global>
  /* ToC link styling */
  .toc-link {
    display: block;
    font-size: 12px;
    font-weight: 500;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: rgba(34, 28, 43, 0.3);
    text-decoration: none;
    padding-left: 12px;
    border-left: 2px solid transparent;
    transition: color 0.2s, border-color 0.2s;
  }
  .toc-link:hover {
    color: rgba(34, 28, 43, 0.6);
  }
  .toc-active {
    color: #9B51E0 !important;
    border-left-color: #9B51E0 !important;
  }
</style>

<script is:inline>
  (function() {
    const content = document.getElementById('entry-content');
    const tocNav = document.getElementById('entry-toc');
    if (!content || !tocNav) return;

    const kickers = content.querySelectorAll('.kicker');
    const tocList = tocNav.querySelector('ul');
    if (!tocList) return;

    const entries = [];

    kickers.forEach((kicker) => {
      // Kicker is inside a <p>, so look from the parent element
      let start = kicker.parentElement.tagName === 'P' ? kicker.parentElement : kicker;
      let el = start.nextElementSibling;
      while (el && el.tagName !== 'H2') {
        el = el.nextElementSibling;
      }
      if (!el) return;

      const h2 = el;
      if (!h2.id) {
        h2.id = kicker.textContent.trim().toLowerCase().replace(/\s+/g, '-');
      }

      const li = document.createElement('li');
      li.style.marginBottom = '12px';
      const a = document.createElement('a');
      a.href = '#' + h2.id;
      a.textContent = kicker.textContent.trim();
      a.className = 'toc-link';
      li.appendChild(a);
      tocList.appendChild(li);

      entries.push({ kicker: kicker, h2: h2, link: a });
    });

    if (entries.length === 0) return;

    const observer = new IntersectionObserver(
      (observed) => {
        observed.forEach((obs) => {
          if (obs.isIntersecting) {
            entries.forEach((e) => e.link.classList.remove('toc-active'));
            const match = entries.find((e) => e.h2 === obs.target);
            if (match) match.link.classList.add('toc-active');
          }
        });
      },
      {
        rootMargin: '-80px 0px -60% 0px',
        threshold: 0,
      }
    );

    entries.forEach((e) => observer.observe(e.h2));
  })();
</script>
