---
import Layout from '../layouts/Layout.astro';
import { getCollection } from 'astro:content';
import ThemeIcon from '../components/ThemeIcon.jsx';

const allEntries = await getCollection('entries', ({ data }) => !data.draft);
const allThemes = await getCollection('themes');
const themes = allThemes.sort((a, b) => a.data.order - b.data.order);

// Count entries per theme
const countByTheme: Record<string, number> = {};
for (const entry of allEntries) {
  const slug = entry.data.theme;
  countByTheme[slug] = (countByTheme[slug] || 0) + 1;
}

const totalEntries = allEntries.length;
---

<Layout title="Themes" description="Browse all 13 themes in the Fieldmarks field guide to systems thinking.">
  <div class="max-w-content mx-auto px-6 md:px-12">

    <!-- Breadcrumb -->
    <div class="pt-24">
      <div class="breadcrumb">
        <a href="/">Home</a>
        <span>/</span>
        <span class="current">Themes</span>
      </div>
    </div>

    <!-- Header -->
    <div class="page-header">
      <h1>Themes</h1>
      <p class="page-subtitle">{totalEntries} concepts across {themes.length} themes. Each theme is a lens on how systems work.</p>
    </div>

    <!-- Theme grid -->
    <div class="theme-grid">
      {themes.map((theme) => (
        <a href={`/theme/${theme.slug}`} class="theme-card">
          <div class="theme-icon">
            <ThemeIcon slug={theme.slug} />
          </div>
          <div class="theme-name">{theme.data.title}</div>
          <div class="theme-desc">{theme.data.subtitle}</div>
          <div class="theme-count">{countByTheme[theme.slug] || 0} concept{(countByTheme[theme.slug] || 0) !== 1 ? 's' : ''}</div>
        </a>
      ))}
    </div>

  </div>
</Layout>

<style>
  .breadcrumb {
    display: flex;
    align-items: center;
    gap: 8px;
    font-size: 14px;
    color: var(--soft);
    margin-bottom: 48px;
  }
  .breadcrumb a {
    color: var(--soft);
    text-decoration: none;
    transition: color 0.2s;
  }
  .breadcrumb a:hover {
    color: var(--accent);
  }
  .breadcrumb .current {
    color: var(--mid);
  }

  .page-header {
    margin-bottom: 48px;
    max-width: 680px;
  }
  .page-header h1 {
    font-size: clamp(38px, 4.5vw, 52px);
    font-weight: 400;
    line-height: 1.12;
    color: var(--deep);
    margin-bottom: 16px;
    letter-spacing: -0.015em;
  }
  .page-subtitle {
    font-size: 20px;
    font-weight: 400;
    line-height: 1.65;
    color: var(--soft);
  }

  /* ====== THEME GRID ====== */
  .theme-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
    gap: 20px;
    margin-bottom: 120px;
  }
  .theme-card {
    padding: 36px;
    background: var(--warm-bg);
    text-decoration: none;
    color: inherit;
    border: 1px solid rgba(34, 28, 43, 0.1);
    transition: transform 0.2s ease, border-color 0.2s ease, box-shadow 0.2s ease;
  }
  .theme-card:hover {
    transform: translateY(-3px);
    border-color: var(--accent);
    box-shadow: 0 4px 12px rgba(34, 28, 43, 0.06);
  }
  .theme-icon {
    width: 40px;
    height: 40px;
    margin-bottom: 20px;
  }
  .theme-name {
    font-size: 19px;
    font-weight: 400;
    color: var(--deep);
    margin-bottom: 8px;
    line-height: 1.3;
    transition: color 0.2s;
  }
  .theme-card:hover .theme-name {
    color: var(--accent);
  }
  .theme-desc {
    font-size: 15px;
    font-weight: 400;
    line-height: 1.6;
    color: var(--soft);
    margin-bottom: 12px;
  }
  .theme-count {
    font-size: 13px;
    font-weight: 400;
    color: var(--soft);
  }

  @media (max-width: 768px) {
    .theme-grid { grid-template-columns: 1fr; }
  }
</style>
