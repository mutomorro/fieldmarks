---
import Layout from '../layouts/Layout.astro';
import { getCollection } from 'astro:content';
import ThemeIcon from '../components/ThemeIcon.jsx';

const allEntries = await getCollection('entries', ({ data }) => !data.draft);
const allThemes = await getCollection('themes');
const themes = allThemes.sort((a, b) => a.data.order - b.data.order);

// Core building blocks theme and its entries
const coreTheme = themes.find(t => t.slug === 'core-building-blocks');
const coreEntries = allEntries
  .filter(e => e.data.theme === 'core-building-blocks')
  .sort((a, b) => a.data.title.localeCompare(b.data.title));

// Theme lookup by slug
const themeBySlug = Object.fromEntries(themes.map(t => [t.slug, t]));

// Grouped themes (excluding core-building-blocks)
const themeGroups = [
  {
    title: "How systems behave",
    slugs: ["system-behaviours", "systems-archetypes", "complexity-and-uncertainty"]
  },
  {
    title: "How to think about systems",
    slugs: ["mental-models", "boundaries-and-power", "human-dimensions"]
  },
  {
    title: "How systems change",
    slugs: ["resilience-and-change", "natural-metaphors", "organisational-systems"]
  },
  {
    title: "How to work with systems",
    slugs: ["leverage-and-intervention", "design-and-intervention", "measurement-and-signals"]
  }
];
---

<Layout title="Themes" description="Browse themes in the Fieldmarks field guide to systems thinking.">
  <div class="max-w-content mx-auto px-6 md:px-12">

    <!-- Breadcrumb -->
    <div class="pt-24">
      <div class="breadcrumb">
        <a href="/">Home</a>
        <span>/</span>
        <span class="current">Themes</span>
      </div>
    </div>

    <!-- Header -->
    <div class="page-header">
      <h1>Themes</h1>
      <p class="page-subtitle">Every system can be understood from different angles - how it behaves, how it changes, where to intervene, what shapes the way we see it. These themes group those angles into starting points. Pick the one that matches what you're noticing.</p>
    </div>

    <!-- Core Building Blocks (elevated) -->
    <div class="core-card">
      <div class="core-start-label">Start here</div>
      <div class="core-icon">
        <ThemeIcon slug="core-building-blocks" />
      </div>
      <h2 class="core-title">Core building blocks</h2>
      <p class="core-desc">The foundations everything else builds on. Start here if you're new to systems thinking.</p>
      <a href="/theme/core-building-blocks" class="core-cta">See all building blocks &rarr;</a>
      <ul class="core-links">
        {coreEntries.map(entry => (
          <li>
            <a href={`/concept/${entry.slug}`} class="core-link">
              {entry.data.title}
              <span class="core-arrow">&rarr;</span>
            </a>
          </li>
        ))}
      </ul>
    </div>

    <!-- Theme groups -->
    {themeGroups.map(group => (
      <div class="theme-group">
        <h2 class="group-heading">{group.title}</h2>
        <div class="group-grid">
          {group.slugs.map(slug => {
            const theme = themeBySlug[slug];
            if (!theme) return null;
            return (
              <a href={`/theme/${theme.slug}`} class="theme-card">
                <div class="theme-icon">
                  <ThemeIcon slug={theme.slug} />
                </div>
                <div class="theme-name">{theme.data.title}</div>
                <div class="theme-desc">{theme.data.subtitle}</div>
              </a>
            );
          })}
        </div>
      </div>
    ))}

  </div>
</Layout>

<style>
  .breadcrumb {
    display: flex;
    align-items: center;
    gap: 8px;
    font-size: 14px;
    color: var(--soft);
    margin-bottom: 48px;
  }
  .breadcrumb a {
    color: var(--soft);
    text-decoration: none;
    transition: color 0.2s;
  }
  .breadcrumb a:hover {
    color: var(--accent);
  }
  .breadcrumb .current {
    color: var(--mid);
  }

  .page-header {
    margin-bottom: 48px;
    max-width: 680px;
  }
  .page-header h1 {
    font-size: clamp(38px, 4.5vw, 52px);
    font-weight: 400;
    line-height: 1.12;
    color: var(--deep);
    margin-bottom: 16px;
    letter-spacing: -0.015em;
  }
  .page-subtitle {
    font-size: 20px;
    font-weight: 400;
    line-height: 1.65;
    color: var(--soft);
  }

  /* ====== CORE BUILDING BLOCKS ====== */
  .core-card {
    padding: 36px;
    border: 1.5px solid var(--accent);
    background: rgba(155, 81, 224, 0.04);
    margin-bottom: 64px;
    max-width: 600px;
  }
  .core-start-label {
    font-size: 11px;
    font-weight: 500;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--accent);
    margin-bottom: 20px;
  }
  .core-icon {
    width: 40px;
    height: 40px;
    margin-bottom: 20px;
  }
  .core-title {
    font-size: 24px;
    font-weight: 400;
    color: var(--deep);
    margin-bottom: 12px;
    line-height: 1.2;
  }
  .core-desc {
    font-size: 15px;
    font-weight: 400;
    line-height: 1.6;
    color: var(--soft);
    margin-bottom: 24px;
  }
  .core-cta {
    display: inline-flex;
    align-items: center;
    font-size: 14px;
    font-weight: 500;
    color: var(--accent);
    text-decoration: none;
    margin-bottom: 28px;
    transition: opacity 0.2s;
  }
  .core-cta:hover {
    opacity: 0.7;
  }
  .core-links {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 6px;
  }
  .core-link {
    display: flex;
    justify-content: space-between;
    align-items: center;
    font-size: 15px;
    font-weight: 400;
    color: var(--deep);
    text-decoration: none;
    padding: 8px 0;
    border-bottom: 1px solid var(--border);
    transition: color 0.2s;
  }
  .core-link:hover {
    color: var(--accent);
  }
  .core-arrow {
    font-size: 14px;
    color: var(--soft);
    transition: color 0.2s, transform 0.2s;
  }
  .core-link:hover .core-arrow {
    color: var(--accent);
    transform: translateX(3px);
  }

  /* ====== THEME GROUPS ====== */
  .theme-group {
    margin-bottom: 48px;
  }
  .group-heading {
    font-size: 24px;
    font-weight: 400;
    color: var(--deep);
    margin-bottom: 24px;
    padding-top: 16px;
  }
  .group-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 20px;
  }

  .theme-card {
    padding: 28px;
    background: var(--warm-bg);
    text-decoration: none;
    color: inherit;
    border: 1px solid var(--border);
    transition: transform 0.2s ease, border-color 0.2s ease, box-shadow 0.2s ease;
  }
  .theme-card:hover {
    transform: translateY(-3px);
    border-color: var(--accent);
    box-shadow: 0 4px 12px rgba(34, 28, 43, 0.06);
  }
  .theme-icon {
    width: 40px;
    height: 40px;
    margin-bottom: 16px;
  }
  .theme-name {
    font-size: 17px;
    font-weight: 400;
    color: var(--deep);
    margin-bottom: 6px;
    line-height: 1.3;
    transition: color 0.2s;
  }
  .theme-card:hover .theme-name {
    color: var(--accent);
  }
  .theme-desc {
    font-size: 14px;
    font-weight: 400;
    line-height: 1.55;
    color: var(--soft);
  }

  @media (max-width: 768px) {
    .group-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 480px) {
    .group-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
